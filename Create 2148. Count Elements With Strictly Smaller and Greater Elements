class Solution {
public:
    int countElements(vector<int>& nums) {
        sort(nums.begin(), nums.end());
        
        int minVal = nums.front();
        int maxVal = nums.back();
        int ans = 0;
        
        for (int i = 1; i < nums.size() - 1; i++) {
            if (nums[i] > minVal && nums[i] < maxVal) {
                ans++;
            }
        }
        return ans;
    }
};
